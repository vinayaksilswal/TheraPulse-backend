datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Product {
  id              String      @id @default(cuid())
  pid             String      @unique // CJ PID
  productName     String
  productSku      String
  sellPrice       Float
  originalPrice   Float
  costPrice       Float
  inventory       Int
  categoryName    String
  productImage    String
  productImages   String[]
  productVideo    String?
  description     String
  highlights      String[]
  tagline         String?
  listCount       Int         @default(0)
  manualSortOrder Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orderItems      OrderItem[]
  socialPosts     SocialPost[]
  emailCampaigns  EmailCampaign[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // TP-Date.now()
  customerName    String
  customerEmail   String?
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  shippingPhone   String?
  totalAmount     Float
  status          String      @default("Pending Dispatch")
  cjOrderId       String?
  paypalOrderId   String?
  auditMargin     Float?
  auditCost       Float?
  auditRevenue    Float?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String? // Changed to optional in case product is deleted
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String  // Store name historically
  quantity  Int
  price     Float
  costPrice Float
  vid       String? // Variant ID used in CJ
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Audience {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  source    String   @default("checkout")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketingState {
  id            String   @id @default("singleton")
  lastSocialIdx Int      @default(0)
  lastEmailIdx  Int      @default(0)
  autoApprove   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model SocialPost {
  id           String   @id @default(cuid())
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  platform     String   // FACEBOOK, INSTAGRAM, BOTH
  type         String   @default("AUTO") // AUTO or MANUAL
  caption      String   @db.Text
  mediaUrls    String[]
  scheduledAt  DateTime
  postedAt     DateTime?
  status       String   @default("DRAFT") // DRAFT, POSTED, FAILED
  errorLog     String?  @db.Text
  fbPostId     String?
  igPostId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailCampaign {
  id           String   @id @default(cuid())
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type         String   @default("AUTO") // AUTO or MANUAL
  subject      String
  bodyText     String   @db.Text
  bodyHtml     String   @db.Text
  scheduledAt  DateTime
  sentAt       DateTime?
  status       String   @default("DRAFT") // DRAFT, SENT, FAILED
  errorLog     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

generator py {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}
